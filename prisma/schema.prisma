generator client {
  provider = "prisma-client-js"
}
model User {
  id             String         @id @default(uuid())
  supabaseId     String?        @unique
  email          String         @unique
  password       String?
  name           String?
  role           String         @default("WORKER")
  organizationId String?
  organization   organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
}

model organization {
  id         String   @id @default(uuid())
  name       String
  inviteCode String?  @unique
  users      User[]
  createdAt  DateTime @default(now())
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model customers {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  phone      String?
  currency   String?    @default("UZS")
  total_cost Decimal?   @default(0) @db.Decimal
  total_paid Decimal?   @default(0) @db.Decimal
  remaining  Decimal?   @default(0) @db.Decimal
  created_at DateTime?  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  payments   payments[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model history {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  action     String?
  details    String?
  created_at DateTime? @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model payments {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id String?    @db.Uuid
  amount      Decimal?   @default(0) @db.Decimal
  currency    String?    @default("UZS")
  created_at  DateTime?  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  customers   customers? @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model bannedIp {
  ip     String  @id
  reason String?
}

model loginAttempt {
  ip    String @id
  count Int    @default(0)
}
